    {
      "id": "sanskrit_04_ehi_ehi_veer_re",
      "folder": "04_ehi_ehi_veer_re",
      "title": "Ehi Ehi Veer Re",
      "notes": [
        {
          "type": "text",
          "text": "##### एहि एहि वीर रे,"
        },
        {
          "type": "text",
          "text": "##### जीवन प्रदर्शित रहे थे"
        },
        {
          "type": "text",
          "text": "वंह हि मार्गदर्शक:"
        },
        {
          "type": "text",
          "text": "वंह हि देशरक्षक:"
        },
        {
          "type": "text",
          "text": "वंह हि शतुनाशक:"
        },
        {
          "type": "text",
          "text": "कालनागतक्षक: ||"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_04_ehi_ehi_veer_re/img_001.jpg",
          "alt": "Image 1"
        },
        {
          "type": "text",
          "text": "##### साहसी सदा भवे:"
        },
        {
          "type": "text",
          "text": "भारतीयसंस्कृत्ति"
        },
        {
          "type": "text",
          "text": "मानसे सदा धेरेः ।।"
        },
        {
          "type": "text",
          "text": "भारतस्य गोरवाय"
        },
        {
          "type": "text",
          "text": "सर्वादौ जयो भवेत् ।।"
        },
        {
          "type": "text",
          "text": "(सं) लक्ष्मीकान्त जाम्बोरकर"
        },
        {
          "type": "text",
          "text": "##### अभ्यास:"
        },
        {
          "type": "text",
          "text": "य: यस्य दण्डलोपी तं समानरर्जेण रुज्यत।"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_04_ehi_ehi_veer_re/img_002.jpg",
          "alt": "Image 2"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_04_ehi_ehi_veer_re/img_003.jpg",
          "alt": "Image 3"
        }
      ],
