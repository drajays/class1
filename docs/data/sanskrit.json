        {
          "type": "text",
          "text": "छात्र: आगच्छित।"
        },
        {
          "type": "text",
          "text": "घोटक: धावित।"
        },
        {
          "type": "text",
          "text": "गायक: गायति ।"
        },
        {
          "type": "text",
          "text": "बालिका कन्दित ।"
        },
        {
          "type": "text",
          "text": "नर्तरी नृत्यित ।"
        },
        {
          "type": "text",
          "text": "यानम् - वाहन, घोटक: - घोड़ा"
        },
        {
          "type": "text",
          "text": "##### क्रियाबोध:"
        },
        {
          "type": "text",
          "text": "बालक: शृणोति ।"
        },
        {
          "type": "text",
          "text": "खग: पश्चात्।"
        },
        {
          "type": "text",
          "text": "छात्र: उतिष्ठति ।"
        },
        {
          "type": "text",
          "text": "बाला उपविशति।"
        },
        {
          "type": "text",
          "text": "साधु: वदित ।"
        },
        {
          "type": "heading",
          "text": "अभ्यास:"
        },
        {
          "type": "text",
          "text": "किसरोति इति लिखित।"
        },
        {
          "type": "text",
          "text": "(लिखित, खादित, पठित)"
        },
        {
          "type": "text",
          "text": ".(खादित, पिबित, गच्छित)"
        },
        {
          "type": "text",
          "text": "(वदिति, हसिति, नमिति)"
        }
      ],
