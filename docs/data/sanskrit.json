    {
      "id": "sanskrit_05_matribhumi_namah",
      "folder": "05_matribhumi_namah",
      "title": "Matribhumi Namah",
      "notes": [
        {
          "type": "heading",
          "text": "मातृभूमि नाम:"
        },
        {
          "type": "text",
          "text": "मातृभूमे नमः मातृभूमे नमः।"
        },
        {
          "type": "text",
          "text": "मातृभूमे नमः मातृभूमे नमः।।"
        },
        {
          "type": "text",
          "text": "अग्रतस्ते नमः पृष्ठतस्ते नमः।"
        },
        {
          "type": "text",
          "text": "वामतस्ते नम: दक्षिणे ते नम:।। मातृभूमे नम:।।"
        },
        {
          "type": "text",
          "text": "ते गिरिभ्यो नमः ते नदीभ्यो नमः।"
        },
        {
          "type": "text",
          "text": "ते वनेभ्यो नमः जनपदेभ्यो नमः॥ मातृभूमे नमः॥"
        },
        {
          "type": "text",
          "text": "प्राप्त होने के बाद देने वैशिक है।"
        },
        {
          "type": "text",
          "text": "ऋதिंदर सिंहदरे भुक्तिमुक्तिप्रदे।"
        },
        {
          "type": "text",
          "text": "सर्वेद सर्वदा देिव तुभ्यं नमः॥ मातृभूमे नमः॥"
        },
        {
          "type": "text",
          "text": "पं. वासुदेव द्वेवेदी शास्त्री"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_05_matribhumi_namah/img_001.jpg",
