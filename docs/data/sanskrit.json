    {
      "id": "sanskrit_07_asiit_nasiti",
      "folder": "07_asiit_nasiti",
      "title": "Asiit Nasiti",
      "notes": [
        {
          "type": "text",
          "text": "##### अर्सित-नास्ति"
        },
        {
          "type": "heading",
          "text": "वृश: अस्ते। फिल्म अस्ते।"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_07_asiit_nasiti/img_001.jpg",
          "alt": "Image 1"
        },
        {
          "type": "heading",
          "text": "वृक्ष: अस्पताल। फलों निष्सित।"
