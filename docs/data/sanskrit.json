        {
          "type": "text",
          "text": "##### वर्णमाला"
        },
        {
          "type": "text",
          "text": "तट: - नदी का किनारा, थ: - पर्वत, दशान: - दाँत, धवल: - सफेद, नयनम् - आँख"
        },
        {
          "type": "text",
          "text": "##### वर्णमाला"
        },
        {
          "type": "text",
          "text": "##### अभ्यास:-१"
        },
        {
          "type": "text",
          "text": "चित्र दृष्टा पदानि लिखत।"
        },
        {
          "type": "heading",
          "text": "二"
        },
        {
          "type": "text",
          "text": "##### अभ्यास:-२"
        },
        {
          "type": "text",
          "text": "अक्षरािण क्रमोण सज्जीकृत्य पदनिर्माणं कुरुत ।"
        }
      ],
