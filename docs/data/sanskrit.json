    {
      "id": "sanskrit_03_matra_parichay",
      "folder": "03_matra_parichay",
      "title": "Matra Parichay",
      "notes": [
        {
          "type": "text",
          "text": "##### मात्रापरिचय:"
        },
        {
          "type": "text",
          "text": "काकः - कौवा, क्रिरणः - क्रिरण, कीटः - कीड़ा, कुमारः - बालक"
        },
        {
          "type": "text",
          "text": "कूपः - कुआँ, कृपणः - कंजूस, केसरः - केसर, कैलासः - कैलास"
        },
        {
          "type": "text",
          "text": "कोमलम् - कोमल, कौमुदी - चन्दमा की क्रिरण, कंसम् - कॉस, कः - कौन"
        },
        {
          "type": "text",
          "text": "##### अभ्यास:-१"
        },
        {
          "type": "heading",
          "text": "अभ्यास:-२"
        },
        {
          "type": "text",
          "text": "रिक्तस्थानपूरणं कुकृतं ।"
        },
        {
          "type": "text",
          "text": "ग् + आ + य + अ + क् + अ:"
        },
        {
          "type": "text",
          "text": "ब् + आ + ***** + अ + क् + अ:"
        },
        {
          "type": "text",
          "text": "गिरी: - ग् + ई + र्+ *****"
        },
        {
          "type": "text",
          "text": "सिललम् - स् + अ + ……+ इ + ल् + ……"
        },
        {
          "type": "text",
          "text": "मौन: - म् + *+ *+ *+ + अ:"
        },
        {
          "type": "text",
          "text": "नगरी - न् + अ + *****+ अ + *****+ ई"
        },
        {
          "type": "text",
          "text": "कुमुद: - क् + …… + म् + …… + द्+ अ:"
        },
        {
          "type": "text",
          "text": "सुखम् - स् + ***** + ख् + अम्"
        },
        {
          "type": "text",
          "text": "गुफ: - ग् + 3+ …… + ……"
        },
        {
          "type": "text",
          "text": "वर्णनिं पृथककृत्य लिखित।"
        },
        {
          "type": "text",
          "text": "##### अभ्यास:-३"
        },
        {
          "type": "heading",
          "text": "अक्षरािण योजितता पदनिर्माण कुरुत।"
        }
      ],
      "questions": [
