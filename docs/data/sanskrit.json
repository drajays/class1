    {
      "id": "sanskrit_02_balgeetani",
      "folder": "02_balgeetani",
      "title": "Balgeetani",
      "notes": [
        {
          "type": "text",
          "text": "##### बालगीतানি"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_02_balgeetani/img_001.jpg",
          "alt": "Image 1"
        },
        {
          "type": "text",
          "text": "##### सूयं: गोलः"
        },
        {
          "type": "text",
          "text": "सुर्य: गोल: चन्द्र: गोल:"
        },
        {
          "type": "text",
          "text": "गोल: मम वागोल:।"
        },
        {
          "type": "text",
          "text": "पृथ्वी गोला चक्रं गोलं"
        },
        {
          "type": "text",
          "text": "गोल: मम रसगोल:॥"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_02_balgeetani/img_002.jpg",
          "alt": "Image 2"
        },
        {
          "type": "text",
          "text": "##### एफ: हस्त:"
        },
        {
          "type": "text",
          "text": "एष: हस्ता: दिक्षणहस्ता:"
        },
        {
          "type": "text",
          "text": "एष: वाम: हस्ता:।"
        },
        {
          "type": "text",
          "text": "एष: पाद: दिक्षणपाद:"
        },
        {
          "type": "text",
          "text": "एष: वाम: पाद:॥"
        },
        {
          "type": "image",
          "src": "assets/content/sanskrit_02_balgeetani/img_003.jpg",
          "alt": "Image 3"
        },
        {
          "type": "text",
          "text": "का सा बाल? काखनमाला!"
        },
        {
          "type": "text",
          "text": "गच्छित कुत्र ? पितुं मित्र।"
        },
        {
          "type": "text",
          "text": "मधुरा बाला । भद्रसुशील।।"
        },
        {
          "type": "text",
          "text": "एवम् ? आम्, आम्।।"
        },
        {
          "type": "text",
          "text": "चलामि मार्ग जले तरामि"
        },
        {
          "type": "text",
          "text": "कूर्दे भूमौ सदा हसामि ।"
        },
        {
          "type": "text",
          "text": "पठामि गेहे कथां शृणोमि"
        },
        {
          "type": "text",
          "text": "भ्रामि नधास्तिरे ।"
        },
        {
          "type": "text",
          "text": "शीतलवायुर्वहित सुमन्दम्"
        },
        {
          "type": "text",
          "text": "आरोहित नौकां नरवृन्द ।"
        }
      ],
